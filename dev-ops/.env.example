# NGINX Proxy Environment Configuration

# Azure MSAL
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
AZURE_API_AUDIENCE=
AZURE_AUTHORITY=https://login.microsoftonline.com/<tenant-id>

# MySQL Configuration (Azure Database for MySQL Flexible Server — one server, four databases)
MYSQL_ROOT_PASSWORD=your_secure_mysql_root_password
MYSQL_USER=appuser
MYSQL_PASSWORD=your_secure_mysql_password
DATABASE_URL_ADMIN=mysql://appuser:apppassword@mysql:3306/app_admin
DATABASE_URL_CUSTOMER=mysql://appuser:apppassword@mysql:3306/app_customer
DATABASE_URL_SCHEDULE=mysql://appuser:apppassword@mysql:3306/app_schedule
DATABASE_URL_SHARED=mysql://appuser:apppassword@mysql:3306/app_shared

# Redis Configuration
REDIS_URL=redis://redis:6379
REDIS_PASSWORD=your_secure_redis_password

# Email Configuration (Optional)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your_email@example.com
SMTP_PASSWORD=your_smtp_password
SMTP_FROM=noreply@yourdomain.com

# Application URLs (for CORS and redirects)
CUSTOMER_WEB_URL=http://localhost
ADMIN_WEB_URL=http://localhost/admin

# API Configuration
API_RATE_LIMIT=100
AUTH_RATE_LIMIT=10

# Node Environment
NODE_ENV=development

# Optional: OpenTelemetry/Monitoring
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4318
ENABLE_METRICS=false
ENABLE_TRACING=false

# Optional: Feature Flags
ENABLE_SOCKET_IO=true
ENABLE_EMAIL_SERVICE=false

# =============================================================================
# n8n Workflow Automation Configuration
# =============================================================================
# For project-specific instances, see: apps/automation/n8n/compose/.env.example
#
# N8N_ENCRYPTION_KEY=generate_with_openssl_rand_hex_32
# N8N_HOST=localhost
# N8N_PORT=5678
# N8N_PROTOCOL=http
# N8N_WEBHOOK_URL=http://localhost:5678
# N8N_DB_HOST=postgres
# N8N_DB_DATABASE=n8n_dev
# N8N_DB_USER=postgres
# N8N_DB_PASSWORD=postgres

