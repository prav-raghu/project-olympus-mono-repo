{
  "name": "project-olympus",
  "private": true,
  "packageManager": "pnpm@11.5.0",
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "dev": "pnpm dev:gateway",
    "dev:gateway": "pnpm --filter @project-olympus/api-gateway dev",
    "dev:customer-api": "pnpm --filter @project-olympus/customer-api dev",
    "dev:admin-api": "pnpm --filter @project-olympus/admin-api dev",
    "dev:schedule-api": "pnpm --filter @project-olympus/schedule-api dev",
    "dev:partner-api": "pnpm --filter @project-olympus/partner-api dev",
    "dev:customer-web": "pnpm --filter customer-web dev",
    "dev:admin-web": "pnpm --filter admin-web dev",
    "dev:mobile": "pnpm --filter @project-olympus/customer-mobile dev",
    "debug:api-gateway": "pnpm --filter @project-olympus/api-gateway build && pnpm --filter @project-olympus/api-gateway start",
    "debug:customer-api": "pnpm --filter @project-olympus/customer-api build && pnpm --filter @project-olympus/customer-api start",
    "debug:admin-api": "pnpm --filter @project-olympus/admin-api build && pnpm --filter @project-olympus/admin-api start",
    "debug:schedule-api": "pnpm --filter @project-olympus/schedule-api build && pnpm --filter @project-olympus/schedule-api start",
    "debug:partner-api": "pnpm --filter @project-olympus/partner-api build && pnpm --filter @project-olympus/partner-api start",
    "build": "turbo run build",
    "test": "turbo run test",
    "test:coverage": "turbo run test:coverage",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "lint:turbo": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "format": "prettier --write \"**/*.{ts,js,json,md,html,scss}\"",
    "format:check": "prettier --check \"**/*.{ts,js,json,md,html,scss}\"",
    "clean": "turbo run clean && rm -rf node_modules",
    "update-deps": "pnpm -r update --latest",
    "update-deps:interactive": "pnpm -r update --interactive --latest",
    "changeset": "changeset",
    "changeset:version": "changeset version",
    "changeset:publish": "pnpm build && changeset publish",
    "changeset:status": "changeset status",
    "docs:export": "tsx dev-ops/scripts/export-api-docs.ts",
    "docs:site": "tsx dev-ops/scripts/generate-api-site.ts",
    "docs:serve": "pnpm docs:site && npx serve documentation/api-site",
    "dev:cms": "docker compose -f dev-ops/docker-compose.dev.yml up directus",
    "n8n:local": "tsx apps/automation/n8n/scripts/start-local.ts",
    "n8n:create-instance": "tsx apps/automation/n8n/scripts/create-instance.ts",
    "sonar": "sonar-scanner",
    "prepare": "husky"
  },
  "devDependencies": {
    "@changesets/changelog-github": "^0.7.0",
    "@changesets/cli": "^2.31.0",
    "@commitlint/cli": "^21.0.2",
    "@commitlint/config-conventional": "^21.0.2",
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.9.1",
    "eslint": "^10.4.1",
    "eslint-plugin-import-x": "^4.16.2",
    "eslint-plugin-sonarjs": "^4.0.3",
    "eslint-plugin-unicorn": "^64.0.0",
    "globals": "^17.6.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.6",
    "prettier": "^3.8.3",
    "tsx": "^4.21.0",
    "turbo": "^2.9.16",
    "typescript-eslint": "^8.60.0"
  },
  "author": "Pravir Raghu"
}
