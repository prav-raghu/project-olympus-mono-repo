{
  "name": "@project-olympus/api-gateway",
  "version": "1.0.0",
  "description": "API Gateway",
  "main": "dist/main.js",
  "scripts": {
    "dev": "tsx watch src/main.ts",
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/main.js",
    "lint": "eslint . --ext .ts",
    "test": "jest",
    "test:watch": "jest --watch",
    "format": "prettier --write .",
    "update-deps": "pnpm update --latest"
  },
  "dependencies": {
    "@nestjs/common": "^10.0.0",
    "@nestjs/core": "^10.0.0",
    "@nestjs/platform-express": "^10.0.0",
    "@nestjs/swagger": "^8.1.1",
    "@nestjs/throttler": "^5.0.0",
    "@project-olympus/auth": "workspace:*",
    "@project-olympus/cache": "workspace:*",
    "@project-olympus/config": "workspace:*",
    "@project-olympus/database": "workspace:*",
    "@project-olympus/email": "workspace:*",
    "@project-olympus/logging": "workspace:*",
    "@project-olympus/queue": "workspace:*",
    "@project-olympus/types": "workspace:*",
    "@project-olympus/utilities": "workspace:*",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.0",
    "dotenv": "^17.4.2",
    "helmet": "^8.0.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.0.0"
  },
  "devDependencies": {
    "@nestjs/testing": "^10.0.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.6.0",
    "jest": "^30.3.0",
    "prettier": "^3.8.3",
    "ts-jest": "^29.4.9",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  },
  "author": "Pravir Raghu"
}
