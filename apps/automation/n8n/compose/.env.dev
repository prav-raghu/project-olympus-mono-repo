# =============================================================================
# n8n Development Instance Environment Variables
# =============================================================================
# Local development configuration - uses shared monorepo Postgres
# =============================================================================

PROJECT_SLUG=dev

# n8n Core Configuration
N8N_ENCRYPTION_KEY=dev_only_not_for_production_change_me_32chars
N8N_HOST=localhost
N8N_PORT=5678
N8N_PROTOCOL=http
WEBHOOK_URL=http://localhost:5678

# Timezone
GENERIC_TIMEZONE=Africa/Johannesburg
TZ=Africa/Johannesburg

# Database Configuration (uses shared monorepo Postgres)
DB_TYPE=postgresdb
DB_POSTGRESDB_HOST=host.docker.internal
DB_POSTGRESDB_PORT=5432
DB_POSTGRESDB_DATABASE=n8n_dev
DB_POSTGRESDB_USER=postgres
DB_POSTGRESDB_PASSWORD=postgres

# Disable auth for local development
N8N_BASIC_AUTH_ACTIVE=false

# Execution Settings
EXECUTIONS_MODE=regular
EXECUTIONS_PROCESS=main
EXECUTIONS_DATA_SAVE_ON_ERROR=all
EXECUTIONS_DATA_SAVE_ON_SUCCESS=all
EXECUTIONS_DATA_PRUNE=true
EXECUTIONS_DATA_MAX_AGE=72

# Logging
N8N_LOG_LEVEL=debug
N8N_LOG_OUTPUT=console

# Disable user management for simple local dev
N8N_USER_MANAGEMENT_DISABLED=true

# Security (relaxed for local dev)
N8N_SECURE_COOKIE=false
