# =============================================================================
# n8n Project Instance Environment Variables
# =============================================================================
# Copy this file to .env.<projectSlug> and update all values
# Example: .env.acme-corp
#
# IMPORTANT: Generate unique N8N_ENCRYPTION_KEY for each project!
# Command: openssl rand -hex 32
# =============================================================================

# -----------------------------------------------------------------------------
# Project Identification
# -----------------------------------------------------------------------------
PROJECT_SLUG=your-project-slug

# -----------------------------------------------------------------------------
# n8n Core Configuration
# -----------------------------------------------------------------------------
N8N_ENCRYPTION_KEY=GENERATE_ME_WITH_openssl_rand_hex_32
N8N_HOST=n8n.your-project-slug.yourdomain.co.za
N8N_PORT=5678
N8N_PROTOCOL=https
WEBHOOK_URL=https://n8n.your-project-slug.yourdomain.co.za

# Timezone (for scheduling)
GENERIC_TIMEZONE=Africa/Johannesburg
TZ=Africa/Johannesburg

# -----------------------------------------------------------------------------
# Database Configuration (PostgreSQL)
# -----------------------------------------------------------------------------
DB_TYPE=postgresdb
DB_POSTGRESDB_HOST=postgres
DB_POSTGRESDB_PORT=5432
DB_POSTGRESDB_DATABASE=n8n_your_project_slug
DB_POSTGRESDB_USER=n8n_your_project_slug
DB_POSTGRESDB_PASSWORD=CHANGE_ME_secure_database_password

# -----------------------------------------------------------------------------
# Authentication (Basic Auth)
# -----------------------------------------------------------------------------
N8N_BASIC_AUTH_ACTIVE=true
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=CHANGE_ME_secure_admin_password

# -----------------------------------------------------------------------------
# Execution Settings
# -----------------------------------------------------------------------------
EXECUTIONS_MODE=regular
EXECUTIONS_PROCESS=main
EXECUTIONS_DATA_SAVE_ON_ERROR=all
EXECUTIONS_DATA_SAVE_ON_SUCCESS=all
EXECUTIONS_DATA_SAVE_ON_PROGRESS=false
EXECUTIONS_DATA_SAVE_MANUAL_EXECUTIONS=true
EXECUTIONS_DATA_PRUNE=true
EXECUTIONS_DATA_MAX_AGE=168

# -----------------------------------------------------------------------------
# Queue Mode (Optional - for scaling)
# -----------------------------------------------------------------------------
# Uncomment to enable Redis queue mode for better performance
# EXECUTIONS_MODE=queue
# QUEUE_BULL_REDIS_HOST=redis
# QUEUE_BULL_REDIS_PORT=6379
# QUEUE_HEALTH_CHECK_ACTIVE=true

# -----------------------------------------------------------------------------
# Logging
# -----------------------------------------------------------------------------
N8N_LOG_LEVEL=info
N8N_LOG_OUTPUT=console

# -----------------------------------------------------------------------------
# Metrics (Optional - for monitoring)
# -----------------------------------------------------------------------------
N8N_METRICS=false
N8N_METRICS_PREFIX=n8n_

# -----------------------------------------------------------------------------
# External Hooks (Optional)
# -----------------------------------------------------------------------------
# EXTERNAL_HOOK_FILES=/data/hooks/external-hooks.js

# -----------------------------------------------------------------------------
# User Management
# -----------------------------------------------------------------------------
N8N_USER_MANAGEMENT_DISABLED=false
N8N_EMAIL_MODE=smtp

# SMTP Configuration (for user invitations)
N8N_SMTP_HOST=smtp.yourdomain.co.za
N8N_SMTP_PORT=587
N8N_SMTP_USER=
N8N_SMTP_PASS=
N8N_SMTP_SENDER=n8n@yourdomain.co.za
N8N_SMTP_SSL=false

# -----------------------------------------------------------------------------
# Security
# -----------------------------------------------------------------------------
N8N_SECURE_COOKIE=true

# Allowed IPs for webhook access (optional)
# N8N_BLOCK_ENV_ACCESS_IN_NODE=true

# -----------------------------------------------------------------------------
# Docker-specific
# -----------------------------------------------------------------------------
N8N_DATA_FOLDER=/home/node/.n8n
