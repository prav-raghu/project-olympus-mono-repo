# Core
NODE_ENV=development
PORT=4000
CORS_ORIGIN=http://localhost:4200

# Azure MSAL
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
AZURE_API_AUDIENCE=
AZURE_AUTHORITY=https://login.microsoftonline.com/<tenant-id>

# Azure Monitor
APPLICATIONINSIGHTS_CONNECTION_STRING=

# MySQL (multi-db)
DATABASE_URL_ADMIN=mysql://appuser:apppassword@localhost:3306/app_admin
DATABASE_URL_CUSTOMER=mysql://appuser:apppassword@localhost:3306/app_customer
DATABASE_URL_SCHEDULE=mysql://appuser:apppassword@localhost:3306/app_schedule
DATABASE_URL_SHARED=mysql://appuser:apppassword@localhost:3306/app_shared
MYSQL_ROOT_PASSWORD=root
MYSQL_USER=appuser
MYSQL_PASSWORD=apppassword
DATABASE_CONNECTION_LIMIT=10

# Redis
REDIS_URL=redis://localhost:6379

# Mailgun
MAILGUN_API_KEY=
MAILGUN_DOMAIN=
MAILGUN_HOST=api.mailgun.net
MAILGUN_FROM=noreply@yourdomain.com

# MailHog (local dev SMTP trap)
MAILHOG_HOST=localhost
MAILHOG_PORT=1025

# Directus
DIRECTUS_SECRET=changeme
DIRECTUS_ADMIN_EMAIL=admin@example.com
DIRECTUS_ADMIN_PASSWORD=

# Storage (unchanged)
AZURE_STORAGE_CONNECTION_STRING=
AZURE_STORAGE_CONTAINER=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=
AWS_S3_BUCKET=

# Rate limiting
RATE_LIMIT_PUBLIC=30
RATE_LIMIT_AUTHENTICATED=120
CACHE_DEFAULT_TTL=900
QUEUE_CONCURRENCY=5

# External APIs (add one block per integration)
# ORG_BILLING_API_BASE_URL=
# ORG_BILLING_API_KEY=
