NODE_ENV=development
LOG_LEVEL=debug

# OpenObserve OTLP endpoints — both optional; omit to disable export (stdout only)
# Start OpenObserve: docker compose -f dev-ops/docker-compose.dev.yml up openobserve -d
OTEL_EXPORTER_OTLP_LOGS_ENDPOINT=http://localhost:5080/api/default/v1/logs
OTEL_EXPORTER_OTLP_TRACES_ENDPOINT=http://localhost:5080/api/default/v1/traces

# Basic auth for OpenObserve — generate: echo -n "admin@example.com:Dev_password1!" | base64
OTEL_EXPORTER_OTLP_HEADERS=Authorization=Basic REPLACE_WITH_BASE64_OF_EMAIL_COLON_PASSWORD

# Pepper for IP hashing — generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
PEPPER=REPLACE_WITH_32_BYTE_HEX
