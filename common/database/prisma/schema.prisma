generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                       String                   @id @default(uuid()) @map("id")
  username                 String                   @unique @map("username")
  password                 String                   @map("password")
  email                    String                   @unique @map("email")
  avatar                   String?                  @map("avatar")
  genderId                 String?                  @map("gender")
  age                      Int?                     @map("age")
  acceptTermsAndConditions Boolean                  @default(false) @map("accept_terms_and_conditions")
  allowEmailCommunications Boolean                  @default(false) @map("allow_email_communications")
  ipAddress                String                   @map("ip_address")
  lastSeen                 DateTime                 @default(now()) @map("last_seen")
  isActive                 Boolean                  @default(true) @map("is_active")
  authHash                 String?                  @map("auth_hash")
  authHashExpiration       DateTime?                @map("auth_hash_expiration")
  twoFactorEnabled         Boolean                  @default(false) @map("two_factor_enabled")
  twoFactorSecret          String?                  @map("two_factor_secret")
  userStatusId             String                   @map("user_status_id")
  status                   UserStatus               @relation(fields: [userStatusId], references: [id])
  roleId                   String                   @map("role_id")
  roles                    Role                     @relation(fields: [roleId], references: [id])
  createdAt                DateTime                 @default(now()) @map("created_at")
  updatedAt                DateTime                 @updatedAt @map("updated_at")
  createdBy                String                   @default("SYSTEM") @map("created_by")
  modifiedBy               String                   @default("SYSTEM") @map("modified_by")

  @@index([isActive, lastSeen])
  @@index([userStatusId, isActive])
  @@index([roleId])
  @@index([authHash])
  @@index([createdAt])
  @@map("users")
}


model Role {
  id         String   @id @default(uuid()) @map("id")
  name       String   @unique @map("name")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")
  createdBy  String   @default("SYSTEM") @map("created_by")
  modifiedBy String   @default("SYSTEM") @map("modified_by")
  isActive   Boolean  @default(true) @map("is_active")
  users      User[]

  @@map("roles")
}

model UserStatus {
  id   String @id @default(uuid()) @map("id")
  name String @unique @map("name")

  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")
  createdBy  String   @default("SYSTEM") @map("created_by")
  modifiedBy String   @default("SYSTEM") @map("modified_by")
  isActive   Boolean  @default(true) @map("is_active")

  users User[]

  @@map("user_statuses")
}

model webhook_subscription {
  id                String   @id @default(uuid())
  url               String
  secret            String
  events            String[]
  is_active         Boolean  @default(true)
  retry_count       Int      @default(3)
  timeout_seconds   Int      @default(30)
  created_by        String?
  created_at        DateTime @default(now())
  updated_at        DateTime @updatedAt
  last_triggered_at DateTime?
  
  deliveries webhook_delivery[]
  
  @@index([is_active])
  @@index([created_at])
  @@map("webhook_subscriptions")
}

model webhook_delivery {
  id              String   @id @default(uuid())
  subscription_id String
  event_type      String
  payload         Json
  status          String
  http_status     Int?
  response_body   String?
  error_message   String?
  attempt_count   Int      @default(0)
  next_retry_at   DateTime?
  delivered_at    DateTime?
  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt
  
  subscription webhook_subscription @relation(fields: [subscription_id], references: [id], onDelete: Cascade)
  
  @@index([subscription_id])
  @@index([status])
  @@index([event_type])
  @@index([created_at])
  @@index([next_retry_at])
  @@map("webhook_deliveries")
}
