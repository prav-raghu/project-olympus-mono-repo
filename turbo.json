{
    "$schema": "https://turbo.build/schema.json",
    "tasks": {
        "build": {
            "dependsOn": ["^build"],
            "inputs": ["src/**/*.ts", "src/**/*.html", "tsconfig.json", "package.json", "angular.json"],
            "outputs": ["dist/**"]
        },
        "dev": {
            "cache": false,
            "persistent": true
        },
        "lint": {
            "dependsOn": ["^build"],
            "inputs": ["src/**/*.ts", "src/**/*.html", "eslint.config.js"]
        },
        "lint:fix": {
            "dependsOn": ["^build"],
            "inputs": ["src/**/*.ts", "src/**/*.html", "eslint.config.js"],
            "cache": false
        },
        "typecheck": {
            "dependsOn": ["^build"],
            "inputs": ["src/**/*.ts", "src/**/*.html", "tsconfig.json"]
        },
        "test": {
            "dependsOn": ["build"],
            "inputs": ["src/**/*.ts", "tests/**/*.ts", "jest.config.ts"],
            "outputs": []
        },
        "test:coverage": {
            "dependsOn": ["build"],
            "inputs": ["src/**/*.ts", "tests/**/*.ts", "jest.config.ts"],
            "outputs": ["coverage/**"]
        },
        "clean": {
            "cache": false
        }
    }
}
